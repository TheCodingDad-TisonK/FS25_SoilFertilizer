<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    Soil PDA Screen
    InGameMenu page — Controller: SoilPDAScreen (src/ui/SoilPDAScreen.lua)

    Layout:
      LEFT  (460px) — context-sensitive sidebar:
          Overview tab  → Full field list (N/P/K/pH/OM/Status), clickable → field detail
          Map tab       → Simple jump list (Field# + Status chip), clickable → centers mini-map
          Treatment tab → Summary stats + hint text
      RIGHT (1000px) — tab content panels (3 tabs: Overview, Soil Map, Treatment)
-->
<GUI name="menuSoilFertilizer">
  <GuiElement profile="fs25_menuContainer">

    <!-- Header bar with icon, title -->
<GuiElement profile="fs25_menuHeaderPanel" position="-200px 90px" width="800px">
<Bitmap profile="fs25_menuHeaderIconBg">
<Bitmap profile="SF_IconMenu"/>
</Bitmap>
<Text profile="fs25_menuHeaderTitle" id="categoryHeaderText" text="$l10n_sf_pda_screen_title"/>
</GuiElement>

    <!-- ══════════════════════════════════════════════════════════════
         LEFT COLUMN — 460px wide, 700px tall, context-sensitive
         ══════════════════════════════════════════════════════════════ -->
    <ThreePartBitmap width="460px" height="700px" position="0px 100px">
      <GuiElement profile="fs25_subCategoryContainer" width="420px">

        <!-- SIDEBAR A: Full field list shown on Overview tab -->
        <GuiElement id="sidebarOverview" position="0px 0px" width="420px" height="640px">
          <Text profile="sf_sectionHeader" text="$l10n_sf_pda_tab_fields" position="10px -10px"/>
          <Text profile="sf_colHeader"      text="$l10n_sf_pda_col_field"  position="10px  -50px" size="60px 24px"/>
          <Text profile="sf_colHeader"      text="N"                        position="76px  -50px" size="58px 24px"/>
          <Text profile="sf_colHeader"      text="P"                        position="138px -50px" size="58px 24px"/>
          <Text profile="sf_colHeader"      text="K"                        position="200px -50px" size="58px 24px"/>
          <Text profile="sf_colHeader"      text="pH"                       position="262px -50px" size="48px 24px"/>
          <Text profile="sf_colHeader"      text="$l10n_sf_pda_col_status" position="314px -50px" size="96px 24px"/>
          <GuiElement position="0px -78px" width="420px" height="552px">
            <SmoothList id="sidebarFieldList" profile="sf_smoothList"
                        startClipperElementName="sideListStart"
                        endClipperElementName="sideListEnd">
              <ListItem profile="sf_listRow" onClick="onClickFieldRow">
                <Bitmap profile="sf_rowBg" name="alternating"/>
                <Text profile="sf_cellLeft"  name="fieldRowId"     size="60px  28px"/>
                <Text profile="sf_cellRight" name="fieldRowN"      position="76px  0" size="58px 28px"/>
                <Text profile="sf_cellRight" name="fieldRowP"      position="138px 0" size="58px 28px"/>
                <Text profile="sf_cellRight" name="fieldRowK"      position="200px 0" size="58px 28px"/>
                <Text profile="sf_cellRight" name="fieldRowPH"     position="262px 0" size="48px 28px"/>
                <Text profile="sf_cellRight" name="fieldRowStatus" position="314px 0" size="96px 28px"/>
              </ListItem>
            </SmoothList>
            <Bitmap profile="fs25_secondaryMenuStartClipper" name="sideListStart"/>
            <Bitmap profile="fs25_secondaryMenuStopClipper"  name="sideListEnd"/>
          </GuiElement>
        </GuiElement>

        <!-- SIDEBAR B: Simple jump list shown on Map tab -->
        <GuiElement id="sidebarMap" position="0px 0px" width="420px" height="640px" visible="false">
          <Text profile="sf_sectionHeader" text="$l10n_sf_pda_tab_fields" position="10px -10px"/>
          <Text profile="sf_subHeader" text="$l10n_sf_pda_map_jump_hint" position="10px -38px" size="400px 22px"/>
          <GuiElement position="0px -65px" width="420px" height="555px">
            <SmoothList id="sidebarMapList" profile="sf_smoothList"
                        startClipperElementName="sideMapStart"
                        endClipperElementName="sideMapEnd">
              <ListItem profile="sf_listRow" onClick="onClickMapJumpRow">
                <Bitmap profile="sf_rowBg" name="alternating"/>
                <Text profile="sf_cellLeft"  name="jumpRowId"     size="90px  28px"/>
                <Text profile="sf_cellRight" name="jumpRowStatus" position="100px 0" size="310px 28px"/>
              </ListItem>
            </SmoothList>
            <Bitmap profile="fs25_secondaryMenuStartClipper" name="sideMapStart"/>
            <Bitmap profile="fs25_secondaryMenuStopClipper"  name="sideMapEnd"/>
          </GuiElement>
        </GuiElement>

        <!-- SIDEBAR C: Treatment summary shown on Treatment tab -->
        <GuiElement id="sidebarTreatment" position="0px 0px" width="420px" height="640px" visible="false">
          <Text profile="sf_sectionHeader" text="$l10n_sf_pda_section_attention" position="10px -10px"/>
          <ThreePartBitmap width="400px" height="220px" position="10px -42px">
            <GuiElement profile="fs25_subCategoryContainer" width="360px">
              <Text profile="sf_statLabel" text="$l10n_sf_pda_needs_fert_label"   position="10px -20px"  size="230px 22px"/>
              <Text profile="sf_statValue" id="treatStatNeedsFert" text="0"        position="245px -20px" size="100px 22px"/>
              <Text profile="sf_statLabel" text="$l10n_sf_pda_weed_label"         position="10px -48px"  size="230px 22px"/>
              <Text profile="sf_statValue" id="treatStatWeed"      text="0"        position="245px -48px" size="100px 22px"/>
              <Text profile="sf_statLabel" text="$l10n_sf_pda_pest_label"         position="10px -76px"  size="230px 22px"/>
              <Text profile="sf_statValue" id="treatStatPest"      text="0"        position="245px -76px" size="100px 22px"/>
              <Text profile="sf_statLabel" text="$l10n_sf_pda_disease_label"      position="10px -104px" size="230px 22px"/>
              <Text profile="sf_statValue" id="treatStatDisease"   text="0"        position="245px -104px" size="100px 22px"/>
              <Text profile="sf_statLabel" text="$l10n_sf_pda_total_urgent_label" position="10px -148px" size="230px 22px"/>
              <Text profile="sf_statValue" id="treatStatTotal"     text="0"        position="245px -148px" size="100px 22px"/>
            </GuiElement>
          </ThreePartBitmap>
          <Text profile="sf_hintText" id="treatHintText"
                text="$l10n_sf_pda_treatment_hint"
                position="10px -275px" size="390px 220px" wrapText="true" textMaxNumLines="6" autoFitHeight="true"/>
        </GuiElement>

      </GuiElement>
    </ThreePartBitmap>

    <!-- ══════════════════════════════════════════════════════════════
         RIGHT COLUMN — 1000px wide, 700px tall, tabbed content
         ══════════════════════════════════════════════════════════════ -->
    <GuiElement id="rightPanel" position="500px 100px" width="1000px" height="700px">

      <!-- TAB 1: FARM OVERVIEW -->
      <GuiElement id="overviewContent" position="0px 0px" width="1000px" height="668px">
        <Text profile="sf_sectionHeader" text="$l10n_sf_pda_section_farm_overview" position="0px 648px"/>
        <ThreePartBitmap width="960px" height="600px" position="0px 40px">
          <GuiElement profile="fs25_subCategoryContainer" width="920px">
            <Text profile="sf_statLabel" text="$l10n_sf_report_fields_tracked"   position="10px -30px"  size="300px 24px"/>
            <Text profile="sf_statValue" id="statsFieldsTracked" text="0"        position="320px -30px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_fields_owned_label"  position="10px -60px"  size="300px 24px"/>
            <Text profile="sf_statValue" id="statsFieldsOwned"   text="0"        position="320px -60px"/>
            <Text profile="sf_subHeader" text="$l10n_sf_pda_section_avg_nutrients" position="10px -110px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_avg_n_label"  position="10px -140px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsAvgN" text="--"         position="320px -140px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_avg_p_label"  position="10px -170px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsAvgP" text="--"         position="320px -170px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_avg_k_label"  position="10px -200px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsAvgK" text="--"         position="320px -200px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_avg_ph_label" position="10px -230px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsAvgPH" text="--"        position="320px -230px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_avg_om_label" position="10px -260px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsAvgOM" text="--"        position="320px -260px"/>
            <Text profile="sf_subHeader" text="$l10n_sf_pda_section_pressure" position="10px -310px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_weed_label"    position="10px -340px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsWeedFields"   text="0"   position="320px -340px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_pest_label"    position="10px -370px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsPestFields"   text="0"   position="320px -370px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_disease_label" position="10px -400px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsDiseaseFields" text="0"  position="320px -400px"/>
            <Text profile="sf_subHeader" text="$l10n_sf_pda_section_attention" position="10px -450px"/>
            <Text profile="sf_statLabel" text="$l10n_sf_pda_needs_fert_label" position="10px -480px" size="300px 24px"/>
            <Text profile="sf_statValue" id="statsNeedsAttention" text="0"    position="320px -480px"/>
          </GuiElement>
        </ThreePartBitmap>
        <Text profile="sf_emptyHint" id="leftNoDataHint" text="$l10n_sf_pda_no_fields"
              position="0px 350px" size="1000px 40px" visible="false"/>
      </GuiElement>

      <!-- TAB 2: SOIL MAP -->
      <GuiElement id="mapContent" position="0px 0px" width="1000px" height="668px" visible="false">
        <Text profile="sf_sectionHeader" text="$l10n_sf_pda_map_section_title" position="0px 658px"/>
        <ThreePartBitmap width="960px" height="170px" position="0px 468px">
          <GuiElement profile="fs25_subCategoryContainer" width="920px">
            <Text profile="sf_detailLabel"      text="$l10n_sf_pda_map_active_layer" position="10px -25px"  size="200px 24px"/>
            <Text profile="sf_detailValueLarge" id="mapLayerName" text="--"           position="220px -25px" size="700px 24px"/>
            <Text profile="sf_detailLabel"      id="mapLayerDesc" text=""             position="10px -55px"  size="900px 40px" wrapText="true" autoFitHeight="true"/>
            <GuiElement id="mapLegendGroup" position="10px -95px" width="900px" height="70px" visible="false">
              <Text profile="sf_subHeader" text="$l10n_sf_pda_map_legend_title" position="0px 60px" size="400px 24px"/>
              <Text profile="sf_legendBlock" id="mapLegendGoodBlock"   text=" " position="0px   25px" size="24px 20px"/>
              <Text profile="sf_legendLabel" id="mapLegendGoodText"    text="$l10n_sf_pda_map_legend_good" position="30px   25px" size="180px 20px"/>
              <Text profile="sf_legendBlock" id="mapLegendFairBlock"   text=" " position="220px 25px" size="24px 20px"/>
              <Text profile="sf_legendLabel" id="mapLegendFairText"    text="$l10n_sf_pda_map_legend_fair" position="250px 25px" size="180px 20px"/>
              <Text profile="sf_legendBlock" id="mapLegendPoorBlock"   text=" " position="440px 25px" size="24px 20px"/>
              <Text profile="sf_legendLabel" id="mapLegendPoorText"    text="$l10n_sf_pda_map_legend_poor" position="470px 25px" size="180px 20px"/>
              <Text profile="sf_legendBlock" id="mapLegendExcessBlock" text=" " position="660px 25px" size="24px 20px"/>
              <Text profile="sf_legendLabel" id="mapLegendExcessText"  text=""  position="690px 25px" size="180px 20px"/>
            </GuiElement>
          </GuiElement>
        </ThreePartBitmap>
        <InGameMapPreview profile="sf_soilMiniMapFull" id="soilMiniMap"/>
      </GuiElement>

      <!-- TAB 3: TREATMENT PLAN -->
      <GuiElement id="treatmentContent" position="0px 0px" width="1000px" height="668px" visible="false">
        <Text profile="sf_sectionHeader" text="$l10n_sf_pda_treatment_section_title" position="0px 648px"/>
        <Text profile="sf_colHeader"      text="$l10n_sf_pda_col_field"    position="8px   618px" size="80px  24px"/>
        <Text profile="sf_colHeader"      text="$l10n_sf_pda_col_priority" position="90px  618px" size="120px 24px"/>
        <Text profile="sf_colHeader"      text="$l10n_sf_pda_col_needs"    position="220px 618px" size="560px 24px"/>
        <Text profile="sf_colHeader"      text="$l10n_sf_pda_col_status"   position="790px 618px" size="170px 24px"/>
        <GuiElement id="treatmentListContainer" position="0px 100px" width="1000px" height="508px">
          <SmoothList id="treatmentList" profile="sf_smoothList"
                      startClipperElementName="tlStart"
                      endClipperElementName="tlEnd">
            <ListItem profile="sf_listRow" onClick="onClickTreatmentRow">
              <Bitmap profile="sf_rowBg" name="alternating"/>
              <Text profile="sf_cellLeft"  name="treatRowId"      size="80px  28px"/>
              <Text profile="sf_cellRight" name="treatRowUrgency" position="90px  0" size="120px 28px"/>
              <Text profile="sf_cellLeft"  name="treatRowNeeds"   position="220px 0" size="760px 28px"/>
            </ListItem>
          </SmoothList>
          <Bitmap profile="fs25_secondaryMenuStartClipper" name="tlStart"/>
          <Bitmap profile="fs25_secondaryMenuStopClipper"  name="tlEnd"/>
          <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
            <Slider profile="fs25_listSlider" dataElementId="treatmentList"/>
          </ThreePartBitmap>
        </GuiElement>
        <Text profile="sf_emptyHint" id="treatmentEmptyHint"
              text="$l10n_sf_pda_no_treatment"
              position="0px 350px" size="1000px 40px" visible="false"/>
      </GuiElement>

      <!-- Tab bar — 3 tabs, evenly spaced -->
      <GuiElement id="tabBar" profile="emptyPanel" position="0px 668px" width="1000px" height="58px">
        <Text   profile="sf_tabLabel"     id="tabLabelOverview"      text="$l10n_sf_pda_section_farm_overview" onClick="onClickTabOverview"   position="0px   30px" size="333px 28px"/>
        <Bitmap profile="sf_tabUnderline" id="tabUnderlineOverview"                                                                            position="0px   28px" size="333px 2px"/>
        <Text   profile="sf_tabLabel"     id="tabLabelMap"           text="$l10n_sf_pda_tab_map"               onClick="onClickTabMap"         position="333px 30px" size="334px 28px"/>
        <Bitmap profile="sf_tabUnderline" id="tabUnderlineMap"                                                                                  position="333px 28px" size="334px 2px" visible="false"/>
        <Text   profile="sf_tabLabel"     id="tabLabelTreatment"     text="$l10n_sf_pda_tab_treatment"         onClick="onClickTabTreatment"   position="667px 30px" size="333px 28px"/>
        <Bitmap profile="sf_tabUnderline" id="tabUnderlineTreatment"                                                                            position="667px 28px" size="333px 2px" visible="false"/>
      </GuiElement>

      <Bitmap profile="sf_tabDivider" position="0px 666px" size="1000px 2px"/>
    </GuiElement><!-- closes rightPanel -->

  </GuiElement><!-- closes menuContainer -->

  <GUIProfiles>
    <Profile name="sf_soilMiniMapFull" extends="baseReference">
      <size value="960px 380px"/>
      <position value="0px 70px"/>
    </Profile>
    <Profile name="SF_IconMenu" extends="baseReference" with="anchorMiddleCenter">
      <size value="50px 50px"/>
      <imageSliceId value="noSlice"/>
      <imageFilename value="g_SFIconMenu"/>
      <imageColor value="$preset_colorTransparent"/>
    </Profile>
    <Profile name="sf_tabLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <isFocusable value="true"/>
      <textSize value="14px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textAlignment value="center"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="sf_tabUnderline" extends="baseReference" with="anchorBottomLeft">
      <imageColor value="0.35 0.85 0.40 1.0"/>
    </Profile>
    <Profile name="sf_tabDivider" extends="baseReference" with="anchorTopLeft">
      <imageColor value="1.0 1.0 1.0 0.12"/>
    </Profile>
    <Profile name="sf_sectionHeader" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="18px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="0.35 0.85 0.40 1.0"/>
    </Profile>
    <Profile name="sf_subHeader" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="13px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="sf_hintText" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="13px"/>
      <textColor value="$preset_colorWhite_50"/>
      <textAlignment value="left"/>
    </Profile>
    <Profile name="sf_statLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite_50"/>
      <textAlignment value="left"/>
      <size value="200px 24px"/>
    </Profile>
    <Profile name="sf_statValue" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textBold value="true"/>
      <textColor value="$preset_colorWhite"/>
      <textAlignment value="right"/>
      <size value="180px 24px"/>
    </Profile>
    <Profile name="sf_detailLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="sf_detailValueLarge" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="16px"/>
      <textBold value="true"/>
      <textColor value="0.35 0.85 0.40 1.0"/>
    </Profile>
    <Profile name="sf_legendBlock" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
    </Profile>
    <Profile name="sf_legendLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="sf_colHeader" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="13px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
      <textAlignment value="left"/>
    </Profile>
    <Profile name="sf_colHeaderRight" extends="sf_colHeader">
      <textAlignment value="right"/>
    </Profile>
    <Profile name="sf_smoothList" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft"/>
    <Profile name="sf_listRow" extends="emptyPanel" with="anchorTopStretchingX pivotTopLeft">
      <height value="28px"/>
    </Profile>
    <Profile name="sf_rowBg" extends="baseReference" with="anchorStretchingYStretchingX">
      <imageColor value="$preset_fs25_colorGrey"/>
      <imageSelectedColor value="0.25 0.65 0.30 0.9"/>
      <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
    </Profile>
    <Profile name="sf_cellLeft" extends="fs25_textDefault" with="anchorStretchingYLeft">
      <position value="8px 0"/>
      <textSize value="13px"/>
      <textAlignment value="left"/>
      <textColor value="$preset_fs25_colorMainLight"/>
      <textSelectedColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <Profile name="sf_cellRight" extends="sf_cellLeft">
      <textAlignment value="right"/>
    </Profile>
    <Profile name="sf_emptyHint" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textAlignment value="center"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
  </GUIProfiles>
</GUI>
