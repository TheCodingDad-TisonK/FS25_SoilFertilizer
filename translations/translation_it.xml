		<e k="helpLine_sf_ov_p2_title" v="Effetti Ambientali" eh="e139e84f" />
		<e k="helpLine_sf_ov_p2_rain_title" v="Pioggia e Lisciviazione" eh="33e0d8ea" />
		<e k="helpLine_sf_ov_p2_rain_text" v="La pioggia liscivia maggiormente l'Azoto, poi il Potassio e infine il Fosforo. Inoltre, acidifica lentamente il pH nel tempo. Questi effetti possono essere disattivati nelle Impostazioni." eh="91e39cc6" />
		<e k="helpLine_sf_ov_p2_season_title" v="Stagioni e Recupero a Riposo" eh="ad2009c8" />
		<e k="helpLine_sf_ov_p2_season_text" v="La primavera aggiunge +0.03 N al giorno (attività biologica). L'autunno rimuove 0.02 N al giorno. I campi lasciati non piantati per più di 7 giorni recuperano lentamente tutti i nutrienti da soli." eh="e5ebb3b2" />
		<e k="helpLine_sf_gs_p1_title" v="Primi Passi" eh="bdd0e0a7" />
		<e k="helpLine_sf_gs_p1_hud_title" v="Apri l'HUD (tasto J)" eh="e1bdea72" />
		<e k="helpLine_sf_gs_p1_hud_text" v="Premi J per attivare l'overlay del suolo. Mostra N, P, K, pH e OM per il campo su cui ti trovi. Le etichette di stato Buono/Sufficiente/Scarso ti indicano subito cosa richiede attenzione." eh="53cef520" />
		<e k="helpLine_sf_gs_p1_report_title" v="Apri il Rapporto Suolo (tasto K)" eh="e71446cd" />
		<e k="helpLine_sf_gs_p1_report_text" v="Premi K per aprire il rapporto completo. Ogni campo è elencato con codici colore, ordinato per urgenza. Clicca sulla freccia in ogni riga per visualizzare dettagli e raccomandazioni." eh="9a0d32a6" />
		<e k="helpLine_sf_gs_p2_title" v="Fertilizzare e Raccogliere" eh="1a52ac04" />
		<e k="helpLine_sf_gs_p2_fert_title" v="Fertilizzazione dei Campi" eh="ea52ec26" />
		<e k="helpLine_sf_gs_p2_fert_text" v="Applica fertilizzante con qualsiasi irroratrice o spandiconcime standard. La mod riconosce i tipi base più 9 tipi personalizzati (UAN-32, MAP, Potassio, ecc.). Ogni tipo ripristina nutrienti diversi - vedi la categoria Fertilizzanti per i profili completi." eh="fe906e29" />
		<e k="helpLine_sf_gs_p2_harvest_title" v="Esaurimento al Raccolto" eh="a67b6cb5" />
		<e k="helpLine_sf_gs_p2_harvest_text" v="Ogni raccolto rimuove nutrienti dal campo. Colture esigenti (patate, barbabietole, soia) consumano molto più di quelle leggere (orzo, avena). Ricontrolla l'HUD dopo ogni ciclo di raccolta." eh="63f90ed4" />
		<e k="helpLine_sf_gs_p3_title" v="Difficoltà" eh="7b29ca96" />
		<e k="helpLine_sf_gs_p3_levels_title" v="Tre Livelli di Difficoltà" eh="52611188" />
		<e k="helpLine_sf_gs_p3_levels_text" v="Semplice (0.7x): 30% in meno di esaurimento. Realistico (1.0x): bilanciato su tassi agricoli reali. Hardcore (1.5x): 50% in più di esaurimento - richiede una gestione intensiva del suolo." eh="f4f1ea30" />
		<e k="helpLine_sf_gs_p3_access_title" v="Modificare le Impostazioni" eh="b421c88f" />
		<e k="helpLine_sf_gs_p3_access_text" v="Apri le impostazioni in ESC > Impostazioni > Suolo &amp; Fertilizzante. In multigiocatore, solo l'amministratore può modificare le impostazioni di simulazione. Le opzioni HUD sono individuali." eh="f36a5639" />
		<e k="helpLine_sf_nu_p1_title" v="Azoto e Fosforo" eh="27d37372" />
		<e k="helpLine_sf_nu_p1_n_title" v="Azoto (N)  —  Scala: da 0 a 100" eh="10a358f4" />
		<e k="helpLine_sf_nu_p1_n_text" v="Nutriente molto mobile: si esaurisce in fretta e si liscivia con la pioggia. Scarso: sotto 30. Buono: sopra 50. Aumenta con: concimi liquidi, UAN, urea, AMS, letame o liquame." eh="58d62253" />
		<e k="helpLine_sf_nu_p1_p_title" v="Fosforo (P)  —  Scala: da 0 a 100" eh="979bba64" />
		<e k="helpLine_sf_nu_p1_p_text" v="Si lega fortemente al suolo. Si consuma principalmente con il raccolto. La colza ha la domanda più alta. Scarso: sotto 25. Buono: sopra 45. Aumenta con: MAP, DAP, fertilizzante starter o liquido." eh="92c5ac66" />
		<e k="helpLine_sf_nu_p2_title" v="Potassio e pH" eh="6bd92f25" />
		<e k="helpLine_sf_nu_p2_k_title" v="Potassio (K) - Scala da 0 a 100" eh="2a16e8bc" />
		<e k="helpLine_sf_nu_p2_k_text" v="Critico per tuberi e radici. Patate e barbabietole consumano molto K. Scarso: sotto 20. Buono: sopra 40. Aumenta con: potassa (0-0-60), liquame, digestato o concime liquido." eh="7230fee4" />
		<e k="helpLine_sf_nu_p2_ph_title" v="pH  —  Scala: da 5.0 a 7.5" eh="944beca2" />
		<e k="helpLine_sf_nu_p2_ph_text" v="Intervallo ideale 6.5 - 7.0. La pioggia acidifica il suolo nel tempo. Il pH non recupera da solo: solo la calce (o calce liquida) lo aumenta. Scarso: sotto 5.5." eh="08e0aefd" />
		<e k="helpLine_sf_nu_p3_title" v="Sostanza Organica" eh="6305f4bb" />
		<e k="helpLine_sf_nu_p3_om_title" v="Sostanza Organica (OM) - Scala da 0 a 10" eh="58f490f3" />
		<e k="helpLine_sf_nu_p3_om_text" v="Si accumula molto lentamente. Scarso: sotto 2.5. Buono: sopra 4.0. Aumenta con: letame, liquame, digestato, compost, biosolidi, pollina o trinciando la paglia in campo." eh="f9a02359" />
		<e k="helpLine_sf_nu_p3_fallow_title" v="Recupero a Riposo" eh="14133b0b" />
		<e k="helpLine_sf_nu_p3_fallow_text" v="Un campo non piantato per 7+ giorni recupera nutrienti. Al giorno: N +0.07, P +0.03, K +0.05, OM +0.01. La rotazione delle colture e il riposo hanno valore reale in questa mod." eh="81fa82b3" />
		<e k="helpLine_sf_fe_p1_title" v="Tipi Base del Gioco" eh="fd941c0d" />
		<e k="helpLine_sf_fe_p1_base_title" v="Liquidi, Solidi, Letame e Liquame" eh="4668dca7" />
		<e k="helpLine_sf_fe_p1_base_text" v="Il fertilizzante liquido aggiunge N+P+K bilanciati. Quello solido è più ricco in N e P. Letame e liquame aggiungono anche Sostanza Organica. Il digestato è ricco in K e OM." eh="64069a56" />
		<e k="helpLine_sf_fe_p1_lime_title" v="Calce e Correzione pH" eh="8933cce1" />
		<e k="helpLine_sf_fe_p1_lime_text" v="La calce corregge il pH ma non aggiunge nutrienti. Tipi personalizzati come Calce Liquida e Gesso influenzano anch'essi il pH. Applica quando il pH scende sotto 6.0." eh="833a967f" />
		<e k="helpLine_sf_fe_p2_title" v="Fonti Personalizzate di Azoto e PK" eh="1021f8c9" />
		<e k="helpLine_sf_fe_p2_n_title" v="Fonti di Azoto (big bags)" eh="9dfe5a5a" />
		<e k="helpLine_sf_fe_p2_n_text" v="UAN-32 e UAN-28 sono soluzioni liquide. L'Ammoniaca Anidra è il prodotto con più N per litro. Urea e AMS sono granulari secchi. Sono prodotti solo azotati (N)." eh="6a100c25" />
		<e k="helpLine_sf_fe_p2_pk_title" v="Fonti di Fosforo e Potassio" eh="a2d4091b" />
		<e k="helpLine_sf_fe_p2_pk_text" v="MAP: massimo fosforo (P). DAP: alto P con un po' di N. Potassio (0-0-60): puro K. Starter (10-34-0): alto P per la semina. Tutti disponibili come big bag nel negozio." eh="75a86964" />
		<e k="helpLine_sf_fe_p3_title" v="Prodotti Organici e Rischio Bruciature" eh="7ab807d1" />
		<e k="helpLine_sf_fe_p3_organic_title" v="Prodotti Organici e a Lento Rilascio" eh="0199e6be" />
		<e k="helpLine_sf_fe_p3_organic_text" v="Il compost è il miglior costruttore di OM (+0.12 per 1000L). Biosolidi e pollina aggiungono N, P e OM. Il letame pellettato è un organico bilanciato e concentrato." eh="3d16e4ee" />
		<e k="helpLine_sf_fe_p3_burn_title" v="Rischio Bruciatura da Sovrapplicazione" eh="e986cc54" />
		<e k="helpLine_sf_fe_p3_burn_text" v="Applicare oltre 1.25x la dose base rischia di 'bruciare' il suolo (-0.15 pH e -5 N). Sopra 1.50x, la bruciatura è garantita. Usa i tasti SF Rate Up/Down per controllare la dose." eh="7bccc46a" />
		<e k="helpLine_sf_hu_p1_title" v="L'HUD del Suolo" eh="6522879b" />
		<e k="helpLine_sf_hu_p1_toggle_title" v="Attivazione HUD (tasto J)" eh="402283ba" />
		<e k="helpLine_sf_hu_p1_toggle_text" v="Premi J per mostrare l'overlay. Rileva il campo e mostra N, P, K, pH e OM. Se attivi Erbacce, Parassiti o Malattie, appariranno righe aggiuntive in fondo al pannello." eh="3dcb9bfe" />
		<e k="helpLine_sf_hu_p1_status_title" v="Leggere lo Stato" eh="291c3aac" />
		<e k="helpLine_sf_hu_p1_status_text" v="Ogni nutriente mostra Buono, Sufficiente o Scarso (resa influenzata). Il distintivo globale nel titolo riflette il valore peggiore tra tutti i parametri monitorati." eh="3b8c2c6e" />
		<e k="helpLine_sf_hu_p2_title" v="Pressioni sulla Salute del Campo" eh="b4d35b30" />
		<e k="helpLine_sf_hu_p2_press_title" v="Erbacce, Parassiti e Malattie" eh="0a3fae00" />
		<e k="helpLine_sf_hu_p2_press_text" v="Tre punteggi (0-100) tracciano le minacce biologiche. Se ignorati, riducono la resa: Erbacce fino a -30%, Parassiti -20%, Malattie -25%. Le righe W, I e D mostrano la gravità col colore." eh="3fc3c400" />
		<e k="helpLine_sf_hu_p2_treat_title" v="Trattare le Pressioni" eh="cb24bf50" />
		<e k="helpLine_sf_hu_p2_treat_text" v="L'erbicida riduce le erbacce (anche la lavorazione del terreno le azzera). L'insetticida riduce i parassiti di 25 punti. Il fungicida riduce le malattie di 20 punti. Sistemi disattivabili nelle Impostazioni." eh="4d65bdec" />
		<e k="helpLine_sf_hu_p3_title" v="Il Rapporto Suolo" eh="35fcce6c" />
		<e k="helpLine_sf_hu_p3_open_title" v="Aprire il Rapporto (tasto K)" eh="62e3f629" />
		<e k="helpLine_sf_hu_p3_open_text" v="Premi K per il rapporto completo. La barra riassuntiva mostra i campi tracciati, quelli che necessitano concime e la salute generale della fattoria in percentuale." eh="38a5bd2e" />
		<e k="helpLine_sf_hu_p3_detail_title" v="Dettagli Campo e Raccomandazioni" eh="c99d2b89" />
		<e k="helpLine_sf_hu_p3_detail_text" v="Clicca sulla freccia di una riga per vedere i valori esatti, la perdita di resa prevista e una lista di raccomandazioni su cosa applicare." eh="38dd2c6d" />
		<e k="helpLine_sf_se_p1_title" v="Impostazioni Simulazione" eh="cbf13e3c" />
		<e k="helpLine_sf_se_p1_server_title" v="Impostazioni Server (Solo Amministratore)" eh="49f37ed7" />
		<e k="helpLine_sf_se_p1_server_text" v="Tutti i sistemi (Nutrienti, Pioggia, Aratura, Malattie, Costi, ecc.) sono gestiti dal server. In multigiocatore, solo l'admin può cambiarli. Le modifiche si sincronizzano istantaneamente." eh="abca5e43" />
		<e k="helpLine_sf_se_p1_diff_title" v="Difficoltà" eh="7b29ca96" />
		<e k="helpLine_sf_se_p1_diff_text" v="Semplice (0.7x), Realistico (1.0x) o Hardcore (1.5x). Cambia l'intensità dell'esaurimento dei nutrienti. Accessibile via ESC > Impostazioni > Suolo &amp; Fertilizzante." eh="740a3a4e" />
		<e k="helpLine_sf_se_p2_title" v="HUD e Controllo Dose" eh="399f4910" />
		<e k="helpLine_sf_se_p2_hud_title" v="Opzioni HUD per Giocatore" eh="0df76500" />
		<e k="helpLine_sf_se_p2_hud_text" v="Ogni giocatore controlla il proprio HUD: posizione, tema colore (Verde/Blu/Ambra/Mono), dimensione carattere e trasparenza." eh="f3934884" />
		<e k="helpLine_sf_se_p2_rate_title" v="Controllo Dose Irroratrice" eh="5ecdfa23" />
		<e k="helpLine_sf_se_p2_rate_text" v="Sui veicoli, usa i tasti SF Rate Up (]) e Down ([) per regolare la dose da 0.10x a 2.00x. Premi Shift+L per il controllo automatico (Auto-Rate) ed evitare bruciature." eh="dd385e39" />
		<e k="helpLine_sf_mp_p1_title" v="Funzionamento Multigiocatore" eh="8a4ce30e" />
		<e k="helpLine_sf_mp_p1_auth_title" v="Simulazione Gestita dal Server" eh="8d324792" />
		<e k="helpLine_sf_mp_p1_auth_text" v="Tutta la simulazione gira sul server. I client ricevono i dati all'accesso. Le impostazioni HUD sono personali e non vengono sincronizzate col server." eh="db72a3f9" />
		<e k="helpLine_sf_mp_p1_ded_title" v="Server Dedicati" eh="4d3a45ba" />
		<e k="helpLine_sf_mp_p1_ded_text" v="Sui server dedicati la simulazione gira normalmente senza HUD. Usa i comandi in console (soilStatus, SoilSetDifficulty, ecc.) per gestire le impostazioni." eh="3df784d6" />
		<e k="helpLine_sf_mp_p2_title" v="Compatibilità Precision Farming" eh="3647a30c" />
		<e k="helpLine_sf_mp_p2_compat_title" v="Eseguire entrambe le Mod" eh="bc5325f5" />
		<e k="helpLine_sf_mp_p2_compat_text" v="Le mod sono indipendenti e compatibili. Una passata di fertilizzante aggiorna entrambe contemporaneamente. PF e SoilFertilizer usano modelli diversi, quindi i valori non saranno identici." eh="5c9f8ada" />
		<e k="helpLine_sf_mp_p2_workflow_title" v="Flusso di Lavoro Pratico" eh="b6f73f04" />
		<e k="helpLine_sf_mp_p2_workflow_text" v="Usa Precision Farming per vedere DOVE nel campo serve attenzione. Usa SoilFertilizer per sapere QUALE nutriente applicare. Una sola passata soddisfa entrambe le mod." eh="cde2c27c" />
