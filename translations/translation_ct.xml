    <e k="helpLine_sf_gs_p1_title" v="首要步驟" eh="bdd0e0a7" />
    <e k="helpLine_sf_gs_p1_hud_title" v="打開 HUD（J 鍵）" eh="e1bdea72" />
    <e k="helpLine_sf_gs_p1_hud_text" v="按 J 鍵切換實時土壤疊層。它顯示你當前田地的 N、P、K、pH 和 OM。良好 / 一般 / 差的狀態標籤讓你一眼看出哪裡需要注意。" eh="53cef520" />
    <e k="helpLine_sf_gs_p1_report_title" v="打開土壤報告（K 鍵）" eh="e71446cd" />
    <e k="helpLine_sf_gs_p1_report_text" v="按 K 鍵打開完整的農場土壤報告。每塊田地都按養分狀態以顏色標註並按緊迫性排序。點擊任何行上的箭頭可查看帶有建議的詳細視圖。" eh="9a0d32a6" />

    <e k="helpLine_sf_gs_p2_title" v="施肥與收穫" eh="1a52ac04" />
    <e k="helpLine_sf_gs_p2_fert_title" v="為田地施肥" eh="ea52ec26" />
    <e k="helpLine_sf_gs_p2_fert_text" v="使用任何標準噴霧器或撒布機施肥。本模組可識別所有原版肥料以及 9 種自定義類型（UAN-32、MAP、鉀肥等）。每種類型恢復不同的養分——詳見肥料類別查看完整簡介。" eh="fe906e29" />
    <e k="helpLine_sf_gs_p2_harvest_title" v="收穫耗損" eh="a67b6cb5" />
    <e k="helpLine_sf_gs_p2_harvest_text" v="每次收穫都會從田中移除養分。高需求作物（馬鈴薯、甜菜、大豆）的耗損明顯高於低需求作物（大麥、燕麥）。每次收穫週期後請重新檢查 HUD 或土壤報告。" eh="63f90ed4" />

    <e k="helpLine_sf_gs_p3_title" v="難度" eh="7b29ca96" />
    <e k="helpLine_sf_gs_p3_levels_title" v="三種難度等級" eh="52611188" />
    <e k="helpLine_sf_gs_p3_levels_text" v="簡單 (0.7x)：耗損減少 30%% - 適合新玩家。真實 (1.0x)：平衡，根據真實農業率校準。硬核 (1.5x)：耗損增加 50%% - 需要精細的土壤管理。" eh="f4f1ea30" />
    <e k="helpLine_sf_gs_p3_access_title" v="更改設置" eh="b421c88f" />
    <e k="helpLine_sf_gs_p3_access_text" v="通過 ESC > 設置 > 土壤與肥料打開設置。在多人遊戲中，只有服務器管理員可以更改模擬設置。所有 HUD 顯示選項均為每位玩家獨立設置，不共享。" eh="f36a5639" />

    <!-- Category 3: Soil Nutrients -->
    <e k="helpLine_sf_nu_p1_title" v="氮和磷" eh="27d37372" />
    <e k="helpLine_sf_nu_p1_n_title" v="氮 (N) — 範圍：0 到 100" eh="10a358f4" />
    <e k="helpLine_sf_nu_p1_n_text" v="移動性最強的養分——耗損最快且在雨中流失嚴重。差：低於 30。良好：高於 50。可通過以下方式提升：液態肥料、UAN-32、UAN-28、無水氨、尿素、AMS、廄肥或泥漿。" eh="58d62253" />
    <e k="helpLine_sf_nu_p1_p_title" v="磷 (P) — 範圍：0 到 100" eh="979bba64" />
    <e k="helpLine_sf_nu_p1_p_text" v="與土壤結合緊密且流失非常緩慢。主要通過收穫耗損。油菜對磷的需求最高。差：低於 25。良好：高於 45。可通過以下方式提升：MAP、DAP、啟動肥或液態肥料。" eh="92c5ac66" />

    <e k="helpLine_sf_nu_p2_title" v="鉀和 pH 值" eh="6bd92f25" />
    <e k="helpLine_sf_nu_p2_k_title" v="鉀 (K) - 範圍 0 到 100" eh="2a16e8bc" />
    <e k="helpLine_sf_nu_p2_k_text" v="對根莖類和塊莖作物至關重要。馬鈴薯和甜菜每次收穫都會大量耗損鉀。在雨中流失中等。差：低於 20。良好：高於 40。可通過以下方式提升：鉀肥 (0-0-60)、泥漿、沼渣或液態肥料。" eh="7230fee4" />
    <e k="helpLine_sf_nu_p2_ph_title" v="pH 值 — 範圍：5.0 到 7.5" eh="944beca2" />
    <e k="helpLine_sf_nu_p2_ph_text" v="大多數作物在 pH 6.5 到 7.0 時生長良好。隨時間推移，降雨會緩慢使土壤酸化。pH 值不會自行恢復——只有石灰或液態石灰能提升它。差：低於 5.5。如果下次播種前 pH 值下降，請施用石灰。" eh="08e0aefd" />

    <e k="helpLine_sf_nu_p3_title" v="有機質" eh="6305f4bb" />
    <e k="helpLine_sf_nu_p3_om_title" v="有機質 (OM) - 範圍 0 到 10" eh="58f490f3" />
    <e k="helpLine_sf_nu_p3_om_text" v="建立非常緩慢且不會被收穫耗損。差：低於 2.5。良好：高於 4.0。可通過以下方式提升：廄肥、泥漿、沼渣、堆肥、生物固形物、雞糞、造粒廄肥，或通過將秸稈粉碎回填到田中。" eh="f9a02359" />
    <e k="helpLine_sf_nu_p3_fallow_title" v="休耕恢復" eh="14133b0b" />
    <e k="helpLine_sf_nu_p3_fallow_text" v="田地若超過 7 天未種植，會緩慢恢復養分。每天：N +0.07, P +0.03, K +0.05, OM +0.01。輪作和休耕期在本模組中具有實際價值。" eh="81fa82b3" />

    <!-- Category 4: Fertilizers -->
    <e k="helpLine_sf_fe_p1_title" v="原版遊戲類型" eh="fd941c0d" />
    <e k="helpLine_sf_fe_p1_base_title" v="液態、固態、廄肥和泥漿" eh="4668dca7" />
    <e k="helpLine_sf_fe_p1_base_text" v="液態肥料添加平衡的 N+P+K。固態肥料含氮磷較高。廄肥和泥漿添加 N、P、K 和有機質。沼渣（生物氣副產品）含鉀量高且同樣添加有機質。均使用標準設備施用。" eh="64069a56" />
    <e k="helpLine_sf_fe_p1_lime_title" v="石灰與 pH 值修正" eh="8933cce1" />
    <e k="helpLine_sf_fe_p1_lime_text" v="石灰是原版遊戲中唯一的 pH 修正方式——它不添加養分。自定義類型液態石灰和石膏也能提升 pH 值（石膏還會添加少量有機質）。當 pH 值降至 6.0 以下時施用，使作物保持在最佳範圍。" eh="833a967f" />

    <e k="helpLine_sf_fe_p2_title" v="自定義氮磷鉀來源" eh="1021f8c9" />
    <e k="helpLine_sf_fe_p2_n_title" v="氮源（自定義大袋）" eh="9dfe5a5a" />
    <e k="helpLine_sf_fe_p2_n_text" v="UAN-32 (32-0-0) 和 UAN-28 (28-0-0) 是液態氮溶液。無水氨 (82-0-0) 是每升含氮量最高的產品。尿素 (46-0-0) 和 AMS (21-0-0-24S) 為乾顆粒。所有這些僅含氮——對磷、鉀或 pH 值無影響。" eh="6a100c25" />
    <e k="helpLine_sf_fe_p2_pk_title" v="磷鉀源" eh="a2d4091b" />
    <e k="helpLine_sf_fe_p2_pk_text" v="MAP (11-52-0)：每升含磷量最高。DAP (18-46-0)：高磷含少量氮。鉀肥 (0-0-60)：純鉀。啟動肥 (10-34-0)：高磷入溝產品，含平衡的氮鉀。均可在商店中購買大袋裝。" eh="75a86964" />

    <e k="helpLine_sf_fe_p3_title" v="有機產品與燒傷風險" eh="7ab807d1" />
    <e k="helpLine_sf_fe_p3_organic_title" v="有機與緩釋產品" eh="0199e6be" />
    <e k="helpLine_sf_fe_p3_organic_text" v="堆肥是最強的有機質建立者（每 1,000 升 +0.12）。生物固形物和雞糞添加氮、磷和有機質。造粒廄肥是濃縮且平衡的有機肥。所有這些均為自定義填充類型，安裝兼容的設備模組後即可使用。" eh="3d16e4ee" />
    <e k="helpLine_sf_fe_p3_burn_title" v="過量施用燒傷風險" eh="e986cc54" />
    <e k="helpLine_sf_fe_p3_burn_text" v="施用量高於基礎率 1.25 倍會有肥料燒傷風險（-0.15 pH 和 -5 N）。達到 1.50 倍或更高時，每次施用必會燒傷（-0.30 pH 和 -12 N）。在車輛中使用施用量增加/減少鍵來控制施用量。" eh="7bccc46a" />

    <!-- Category 5: HUD and Soil Report -->
    <e k="helpLine_sf_hu_p1_title" v="土壤 HUD" eh="6522879b" />
    <e k="helpLine_sf_hu_p1_toggle_title" v="切換 HUD（J 鍵）" eh="402283ba" />
    <e k="helpLine_sf_hu_p1_toggle_text" v="按 J 鍵顯示或隱藏實時土壤疊層。它檢測你所在的田地並顯示 N、P、K、pH 和 OM。當啟用雜草、害蟲或疾病設置時，相關行會出現在面板底部。" eh="3dcb9bfe" />
    <e k="helpLine_sf_hu_p1_status_title" v="閱讀狀態" eh="291c3aac" />
    <e k="helpLine_sf_hu_p1_status_text" v="每種養分顯示良好（無需操作）、一般（考慮近期處理）或差（需要操作——影響產量）。標題欄中的總體徽章反映了所有監測維度（包括雜草、害蟲和疾病）中的最差值。" eh="3b8c2c6e" />

    <e k="helpLine_sf_hu_p2_title" v="田地健康壓力" eh="b4d35b30" />
    <e k="helpLine_sf_hu_p2_press_title" v="雜草、害蟲和疾病" eh="0a3fae00" />
    <e k="helpLine_sf_hu_p2_press_text" v="田地的生物威脅由三種壓力分數（0 到 100）追蹤。若不加處理，收穫時會降低產量：雜草最高 -30%%，害蟲 -20%%，疾病 -25%%。HUD 行 W、I 和 D 顯示顏色標註的嚴重程度：綠色（低）、黃色（中等）、紅色（高）。" eh="3fc3c400" />
    <e k="helpLine_sf_hu_p2_treat_title" v="處理壓力" eh="cb24bf50" />
    <e k="helpLine_sf_hu_p2_treat_text" v="除草劑減少雜草壓力——任何耕作也會將其重置為零。殺蟲劑減少 25 點害蟲壓力並抑制再生長 10 天。殺菌劑減少 20 點疾病並抑制 12 天。每套系統均可在設置中關閉。" eh="4d65bdec" />

    <e k="helpLine_sf_hu_p3_title" v="土壤報告" eh="35fcce6c" />
    <e k="helpLine_sf_hu_p3_open_title" v="打開報告（K 鍵）" eh="62e3f629" />
    <e k="helpLine_sf_hu_p3_open_text" v="按 K 鍵打開完整的農場土壤報告。摘要欄顯示追蹤的田地總數、有多少需要施肥，以及權重的農場健康百分比。田地按緊迫性排序——狀況最差的優先。" eh="38a5bd2e" />
    <e k="helpLine_sf_hu_p3_detail_title" v="田地詳情與建議" eh="c99d2b89" />
    <e k="helpLine_sf_hu_p3_detail_text" v="點擊任何行上的箭頭以打開該田地的詳細視圖：養分值、壓力等級、產量損失預測，以及列出具體施用建議的清單。按返回或 Escape 鍵回到表格。" eh="38dd2c6d" />

    <!-- Category 6: Settings -->
    <e k="helpLine_sf_se_p1_title" v="模擬設置" eh="cbf13e3c" />
    <e k="helpLine_sf_se_p1_server_title" v="服務器設置（多人遊戲中僅管理員可用）" eh="49f37ed7" />
    <e k="helpLine_sf_se_p1_server_text" v="肥力系統、養分循環、季節效應、降雨效應、翻耕獎勵、雜草/害蟲/疾病壓力、肥料成本、通知、作物輪作和自動施用量控制。在多人遊戲中，只有服務器管理員可以更改這些。更改會立即同步到所有客戶端。" eh="abca5e43" />
    <e k="helpLine_sf_se_p1_diff_title" v="難度" eh="7b29ca96" />
    <e k="helpLine_sf_se_p1_diff_text" v="簡單 (0.7x) 減少 30%% 耗損，提供輕鬆體驗。真實 (1.0x) 是平衡的默認設置。硬核 (1.5x) 增加 50%% 耗損，用於精細土壤管理。通過 ESC > 設置 > 土壤與肥料訪問。" eh="740a3a4e" />

    <e k="helpLine_sf_se_p2_title" v="HUD 與施用量控制" eh="399f4910" />
    <e k="helpLine_sf_se_p2_hud_title" v="每位玩家 HUD 選項" eh="0df76500" />
    <e k="helpLine_sf_se_p2_hud_text" v="每位玩家控制自己的 HUD——不與服務器同步。選項：顯示 HUD（開/關）、位置（5 個預設 + 拖動）、顏色主題（綠 / 藍 / 琥珀 / 單色）、字體大小（小 / 中 / 大）、透明度（25%% 到 100%%）、英制單位（開/關）。" eh="f3934884" />
    <e k="helpLine_sf_se_p2_rate_title" v="噴霧機施用量控制" eh="5ecdfa23" />
    <e k="helpLine_sf_se_p2_rate_text" v="在噴霧器或撒布機中，使用 SF 施用量增加 (]) 和 SF 施用量減少 ([) 來將施用量從 0.10x 調整到 2.00x。切換自動施用量控制 (Shift+L) 以讓模組自動瞄準最佳養分水平並避免燒傷風險。" eh="dd385e39" />

    <!-- Category 7: Multiplayer and PrecisionFarming -->
    <e k="helpLine_sf_mp_p1_title" v="多人遊戲工作機制" eh="8a4ce30e" />
    <e k="helpLine_sf_mp_p1_auth_title" v="服務器授權模擬" eh="8d324792" />
    <e k="helpLine_sf_mp_p1_auth_text" v="所有土壤模擬均在服務器上運行。客戶端在加入時接收完整的田地數據和設置，如果服務器仍在加載中則會自動重試。HUD 顯示設置（位置、主題、大小）是每位玩家獨立的，絕不會同步到服務器。" eh="db72a3f9" />
    <e k="helpLine_sf_mp_p1_ded_title" v="專用服務器" eh="4d3a45ba" />
    <e k="helpLine_sf_mp_p1_ded_text" v="專用服務器運行完整的模擬，沒有任何 HUD 或 GUI 開銷——這是預期且正常的。使用控制台命令（soilStatus、SoilSetDifficulty、SoilShowSettings 等）在專用服務器上管理和驗證設置。" eh="3df784d6" />

    <e k="helpLine_sf_mp_p2_title" v="PrecisionFarming 兼容性" eh="3647a30c" />
    <e k="helpLine_sf_mp_p2_compat_title" v="同時運行兩個模組" eh="bc5325f5" />
    <e k="helpLine_sf_mp_p2_compat_text" v="兩個模組完全獨立運行且完全兼容。一次施肥作業會同時更新兩者——你不需要施肥兩次。PF 的土壤分區和 SoilFertilizer 的 N/P/K 值使用不同模型，因此不會完全相同。" eh="5c9f8ada" />
    <e k="helpLine_sf_mp_p2_workflow_title" v="實用工作流程" eh="b6f73f04" />
    <e k="helpLine_sf_mp_p2_workflow_text" v="使用 PrecisionFarming 查看田地中哪裡需要注意（分區精度）。使用 SoilFertilizer 的 HUD 和土壤報告查看需要施用什麼養分。一次作業可同時滿足兩個模組，且它們絕不會給出相互矛盾的建議。" eh="cde2c27c" />

    <e k="sf_crop_rotation_short" v="作物輪作" eh="def2c162" />
    <e k="sf_crop_rotation_long" v="啟用/禁用作物輪作獎勵和連作疲勞（豆科植物序列可恢復氮；同種作物連續種植會增加耗損）" eh="958b4212" />
    <e k="sf_report_rotation_bonus" v="輪作獎勵" eh="2831a7ac" />
    <e k="sf_report_rotation_fatigue" v="連作疲勞：相同作物" eh="46135880" />
    <e k="sf_report_rotation_ok" v="輪作：正常" eh="df66b3be" />
    <e k="sf_gypsum_title" v="石膏 (pH+)" eh="56e6dc36" />
    <e k="sf_compost_title" v="堆肥 (有機)" eh="c3e2071a" />
    <e k="sf_biosolids_title" v="生物固形物 (N+P)" eh="f0c901dc" />
    <e k="sf_chicken_manure_title" v="雞糞 (N+P)" eh="338128e2" />
    <e k="sf_pelletized_manure_title" v="造粒廄肥 (NPK)" eh="c1b39b71" />
    <e k="sf_liquidlime_title" v="液態石灰 (pH+)" eh="d4ec4bb9" />
    <e k="helpLine_sf_nu_p4_title" v="作物輪作" eh="def2c162" />
    <e k="helpLine_sf_nu_p4_bonus_title" v="輪作獎勵" eh="2831a7ac" />
    <e k="helpLine_sf_nu_p4_bonus_text" v="在非豆科作物後種植豆科作物（大豆、豌豆、蠶豆），會在每年春季增加為期 3 天的免費氮素提升。" eh="e1fce95b" />
    <e k="helpLine_sf_nu_p4_fatigue_title" v="作物疲勞" eh="236a590c" />
    <e k="helpLine_sf_nu_p4_fatigue_text" v="連續兩季種植同一種作物會使養分提取量增加 15%%。請輪作作物以避免土壤疲勞。" eh="1613f3c6" />

    <!-- Soil Map Overlay (SoilMapOverlay.lua) -->
    <e k="sf_map_layer_off" v="土壤地圖：關閉" eh="3e654ade" />
    <e k="sf_map_layer_n" v="氮" eh="1e9ef3ba" />
    <e k="sf_map_layer_p" v="磷" eh="eb4f2688" />
    <e k="sf_map_layer_k" v="鉀" eh="3a4edc67" />
    <e k="sf_map_layer_ph" v="pH 值" eh="397dff20" />
    <e k="sf_map_layer_om" v="有機質" eh="6305f4bb" />
    <e k="sf_map_layer_urgency" v="田地緊迫性" eh="419ea5af" />
    <e k="sf_map_layer_weed" v="雜草壓力" eh="53f8b936" />
    <e k="sf_map_layer_pest" v="害蟲壓力" eh="18a7c2be" />
    <e k="sf_map_layer_disease" v="疾病壓力" eh="2b805cc9" />
    <e k="sf_map_overlay_cycle" v="Shift+M: 切換土壤圖層" eh="032fdac7" />
    <e k="sf_map_page_title" v="土壤圖層" eh="04a675fb" />
    <e k="sf_map_sidebar_header" v="土壤地圖圖層" eh="81332549" />
    <e k="sf_map_sidebar_label" v="活動圖層" eh="f8a2c198" />
