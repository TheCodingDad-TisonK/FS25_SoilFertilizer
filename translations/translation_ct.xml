    <!-- Category 1: Overview -->
    <e k="helpLine_sf_ov_p1_title" v="功能簡介" eh="46cbb25b" />
    <e k="helpLine_sf_ov_p1_intro_title" v="田地土壤追蹤" eh="8fe3248d" />
    <e k="helpLine_sf_ov_p1_intro_text" v="每塊田地獨立追蹤五種屬性：氮 (N)、磷 (P)、鉀 (K)、有機質 (OM) 和 pH 值。數值會隨存檔保存，並在不同會話間持久存在。" eh="c30216e6" />
    <e k="helpLine_sf_ov_p1_flow_title" v="養分循環" eh="15b0d408" />
    <e k="helpLine_sf_ov_p1_flow_text" v="作物在收穫時會移除養分。肥料、廄肥、泥漿和石灰可恢復養分。本模組追蹤真實的養分收支——作物帶走多少，你就必須補充多少。" eh="418041f0" />

    <e k="helpLine_sf_ov_p2_title" v="環境影響" eh="e139e84f" />
    <e k="helpLine_sf_ov_p2_rain_title" v="降雨與流失" eh="33e0d8ea" />
    <e k="helpLine_sf_ov_p2_rain_text" v="降雨對氮的沖刷最嚴重，其次是鉀，然後是磷。隨時間推移，它還會緩慢使 pH 值酸化。降雨效應可在設置中關閉。" eh="91e39cc6" />
    <e k="helpLine_sf_ov_p2_season_title" v="季節與休耕恢復" eh="ad2009c8" />
    <e k="helpLine_sf_ov_p2_season_text" v="春季每天增加 +0.03 氮（生物活動）。秋季每天移除 0.02 氮。田地若超過 7 天未種植，會自行緩慢恢復所有養分。" eh="e5ebb3b2" />

