    <!-- ======================================================
         HELP LINES (ESC > Help > Realistic Soil & Fertilizer)
         ====================================================== -->

    <!-- Category titles -->
    <e k="helpLine_sf_cat_overview" v="概要" eh="3b878279" />
    <e k="helpLine_sf_cat_started" v="はじめに" eh="bf647454" />
    <e k="helpLine_sf_cat_nutrients" v="土壌養分" eh="64377acf" />
    <e k="helpLine_sf_cat_fertilizers" v="肥料" eh="754d59bd" />
    <e k="helpLine_sf_cat_hud" v="HUDと土壌レポート" eh="655b1b40" />
    <e k="helpLine_sf_cat_settings" v="設定" eh="f4f70727" />
    <e k="helpLine_sf_cat_multiplayer" v="マルチプレイヤー" eh="901a7320" />

    <!-- Category 1: Overview -->
    <e k="helpLine_sf_ov_p1_title" v="Modの機能" eh="46cbb25b" />
    <e k="helpLine_sf_ov_p1_intro_title" v="フィールドごとの土壌追跡" eh="8fe3248d" />
    <e k="helpLine_sf_ov_p1_intro_text" v="すべてのフィールドで、窒素 (N)、リン (P)、カリウム (K)、有機物 (OM)、および pH の 5 つの特性を個別に追跡します。値はセーブデータに保存され、セッションを跨いで保持されます。" eh="c30216e6" />
    <e k="helpLine_sf_ov_p1_flow_title" v="養分サイクル" eh="15b0d408" />
    <e k="helpLine_sf_ov_p1_flow_text" v="作物は収穫時に養分を消費します。肥料、堆肥、液肥、石灰によってこれらを回復させます。Mod は現実的な養分収支を追跡し、作物が取り出した分だけ補充する必要があります。" eh="418041f0" />

    <e k="helpLine_sf_ov_p2_title" v="環境の影響" eh="e139e84f" />
    <e k="helpLine_sf_ov_p2_rain_title" v="雨と流出" eh="33e0d8ea" />
    <e k="helpLine_sf_ov_p2_rain_text" v="雨により窒素が最も激しく流出し、次いでカリウム、リンの順に影響を受けます。また、時間の経過とともに pH が徐々に酸性化します。雨の影響は設定でオフにできます。" eh="91e39cc6" />
    <e k="helpLine_sf_ov_p2_season_title" v="季節と休耕地の回復" eh="ad2009c8" />
    <e k="helpLine_sf_ov_p2_season_text" v="春には生物活動により 1 日あたり +0.03 N 加算されます。秋には 1 日あたり 0.02 N 減少します。7 日以上作付けされていないフィールドは、徐々にすべての養分が自律回復します。" eh="e5ebb3b2" />

    <!-- Category 2: Getting Started -->
    <e k="helpLine_sf_gs_p1_title" v="最初のステップ" eh="bdd0e0a7" />
    <e k="helpLine_sf_gs_p1_hud_title" v="HUD を開く (J キー)" eh="e1bdea72" />
    <e k="helpLine_sf_gs_p1_hud_text" v="J キーでライブ土壌オーバーレイを切り替えます。現在立っているフィールドの N、P、K、pH、OM を表示します。「良好 / 普通 / 不良」のラベルで、何に注意が必要か一目でわかります。" eh="53cef520" />
    <e k="helpLine_sf_gs_p1_report_title" v="土壌レポートを開く (K キー)" eh="e71446cd" />
    <e k="helpLine_sf_gs_p1_report_text" v="K キーで農場全体の土壌レポートを開きます。すべてのフィールドが養分状態ごとに色分けされ、緊急度順にリストされます。各行の矢印をクリックすると、推奨事項を含む詳細ビューが表示されます。" eh="9a0d32a6" />

    <e k="helpLine_sf_gs_p2_title" v="施肥と収穫" eh="1a52ac04" />
    <e k="helpLine_sf_gs_p2_fert_title" v="フィールドへの施肥" eh="ea52ec26" />
    <e k="helpLine_sf_gs_p2_fert_text" v="標準のスプレイヤーやスプレッダーで肥料を散布します。Mod はバニラの肥料に加え、9 つのカスタムタイプ（UAN-32、MAP、塩化カリなど）を認識します。タイプごとに回復する養分が異なります。" eh="fe906e29" />
    <e k="helpLine_sf_gs_p2_harvest_title" v="収穫による消耗" eh="a67b6cb5" />
    <e k="helpLine_sf_gs_p2_harvest_text" v="収穫ごとにフィールドから養分が取り除かれます。要求量の多い作物（ジャガイモ、テンサイ、大豆）は、軽い作物（大麦、オーツ麦）よりも大幅に養分を消費します。収穫ごとにレポートを確認しましょう。" eh="63f90ed4" />

    <e k="helpLine_sf_gs_p3_title" v="難易度" eh="7b29ca96" />
    <e k="helpLine_sf_gs_p3_levels_title" v="3 つの難易度レベル" eh="52611188" />
    <e k="helpLine_sf_gs_p3_levels_text" v="簡易 (0.7x): 消耗が 30% 減少。リアル (1.0x): 現実の農業レートに調整。ハードコア (1.5x): 消耗が 50% 増加し、集中的な土壌管理が必要になります。" eh="f4f1ea30" />
    <e k="helpLine_sf_gs_p3_access_title" v="設定の変更" eh="b421c88f" />
    <e k="helpLine_sf_gs_p3_access_text" v="ESC > 設定 > 土壌と肥料から設定を開きます。マルチプレイヤーでは、サーバー管理者のみがシミュレーション設定を変更できます。HUD の表示オプションは各プレイヤーごとに設定可能です。" eh="4ba9d860" />

    <!-- Category 3: Soil Nutrients -->
    <e k="helpLine_sf_nu_p1_title" v="窒素とリン" eh="27d37372" />
    <e k="helpLine_sf_nu_p1_n_title" v="窒素 (N) - スケール 0 〜 100" eh="10a358f4" />
    <e k="helpLine_sf_nu_p1_n_text" v="最も移動しやすい養分で、消耗が速く雨による流出も激しいです。不良: 30 未満。良好: 50 以上。液体肥料、UAN-32、尿素、無水アンモニア、堆肥などで補給します。" eh="58d62253" />
    <e k="helpLine_sf_nu_p1_p_title" v="リン (P) - スケール 0 〜 100" eh="979bba64" />
    <e k="helpLine_sf_nu_p1_p_text" v="土壌に強く結合し、流出は非常に緩やかです。主に収穫によって減少します。キャノーラは最もリンを要求します。不良: 25 未満。良好: 45 以上。MAP、DAP、スターター肥料などで補給します。" eh="92c5ac66" />

    <e k="helpLine_sf_nu_p2_title" v="カリウムと pH" eh="6bd92f25" />
    <e k="helpLine_sf_nu_p2_k_title" v="カリウム (K) - スケール 0 〜 100" eh="2a16e8bc" />
    <e k="helpLine_sf_nu_p2_k_text" v="根菜類に不可欠です。ジャガイモやテンサイは収穫ごとに大量の K を消費します。雨で適度に流出します。不良: 20 未満。良好: 40 以上。塩化カリ、液肥、液体肥料などで補給します。" eh="7230fee4" />
    <e k="helpLine_sf_nu_p2_ph_title" v="pH - スケール 5.0 〜 7.5" eh="944beca2" />
    <e k="helpLine_sf_nu_p2_ph_text" v="ほとんどの作物は pH 6.5 〜 7.0 でよく育ちます。雨は時間をかけて土壌を酸性化させます。pH は自然には回復しません。石灰や液体石灰のみが pH を上昇させます。不良: 5.5 未満。" eh="08e0aefd" />

    <e k="helpLine_sf_nu_p3_title" v="有機物" eh="6305f4bb" />
    <e k="helpLine_sf_nu_p3_om_title" v="有機物 (OM) - スケール 0 〜 10" eh="58f490f3" />
    <e k="helpLine_sf_nu_p3_om_text" v="蓄積は非常に遅く、収穫では減少しません。不良: 2.5 未満。良好: 4.0 以上。堆肥、液肥、バイオソリッド、鶏糞、または藁をフィールドに漉き込むことで増加します。" eh="f9a02359" />
    <e k="helpLine_sf_nu_p3_fallow_title" v="休耕による回復" eh="14133b0b" />
    <e k="helpLine_sf_nu_p3_fallow_text" v="7 日以上作付けされていないフィールドは養分を回復します。1 日あたり: N +0.07, P +0.03, K +0.05, OM +0.01。輪作や休耕期間はこの Mod において実利的な価値があります。" eh="81fa82b3" />

    <!-- Category 4: Fertilizers -->
    <e k="helpLine_sf_fe_p1_title" v="バニラの肥料" eh="fd941c0d" />
    <e k="helpLine_sf_fe_p1_base_title" v="液体、固形、堆肥、液肥" eh="4668dca7" />
    <e k="helpLine_sf_fe_p1_base_text" v="液体肥料はバランス良く NPK を追加します。固形肥料は N と P が高めです。堆肥と液肥は NPK に加え有機物を追加します。消化液は K が豊富で、有機物も追加します。" eh="64069a56" />
    <e k="helpLine_sf_fe_p1_lime_title" v="石灰と pH 矯正" eh="8933cce1" />
    <e k="helpLine_sf_fe_p1_lime_text" v="石灰はバニラで唯一の pH 矯正手段であり、養分は追加しません。カスタムの液体石灰や石膏も pH を上昇させます。pH が 6.0 を下回ったら、最適な範囲を保つために散布してください。" eh="833a967f" />

    <e k="helpLine_sf_fe_p2_title" v="カスタムの窒素・リン・カリ源" eh="1021f8c9" />
    <e k="helpLine_sf_fe_p2_n_title" v="窒素源（カスタムビッグバッグ）" eh="9dfe5a5a" />
    <e k="helpLine_sf_fe_p2_n_text" v="UAN-32 と UAN-28 は液体窒素溶液です。無水アンモニアは 1L あたりの N 含有量が最大です。尿素と AMS は乾燥顆粒です。これらは窒素 (N) のみを含み、P、K、pH には影響しません。" eh="6a100c25" />
    <e k="helpLine_sf_fe_p2_pk_title" v="リン・カリウム源" eh="a2d4091b" />
    <e k="helpLine_sf_fe_p2_pk_text" v="MAP: リン含有量が最大。DAP: 高リンで少量の窒素を含む。塩化カリ: 純粋なカリウム。スターター: N と K のバランスが取れた高リン製品。これらはショップでビッグバッグとして購入できます。" eh="75a86964" />

    <e k="helpLine_sf_fe_p3_title" v="有機製品と肥料焼けのリスク" eh="7ab807d1" />
    <e k="helpLine_sf_fe_p3_organic_title" v="有機・緩効性肥料" eh="0199e6be" />
    <e k="helpLine_sf_fe_p3_organic_text" v="堆肥は最強の有機物供給源です。バイオソリッドと鶏糞は N、P、有機物を追加します。ペレット堆肥は濃縮されたバランスの良い有機肥料です。これらは対応する Mod 導入時に利用可能です。" eh="3d16e4ee" />
    <e k="helpLine_sf_fe_p3_burn_title" v="過剰散布による肥料焼け" eh="e986cc54" />
    <e k="helpLine_sf_fe_p3_burn_text" v="基準の 1.25 倍を超えて散布すると肥料焼けのリスクがあります。1.50 倍以上では、散布のたびにダメージ（pH -0.30, N -12）が確定します。車両内のレート調整キーで散布量を管理してください。" eh="7bccc46a" />

    <!-- Category 5: HUD and Soil Report -->
    <e k="helpLine_sf_hu_p1_title" v="土壌 HUD" eh="6522879b" />
    <e k="helpLine_sf_hu_p1_toggle_title" v="HUD の切り替え (J キー)" eh="402283ba" />
    <e k="helpLine_sf_hu_p1_toggle_text" v="J キーで土壌オーバーレイの表示/非表示を切り替えます。現在地のフィールドを検出し、N、P、K、pH、OM を表示します。雑草、害虫、病害設定が有効な場合、それらもパネル下部に表示されます。" eh="3dcb9bfe" />
    <e k="helpLine_sf_hu_p1_status_title" v="ステータスの読み方" eh="291c3aac" />
    <e k="helpLine_sf_hu_p1_status_text" v="各養分は「良好（対応不要）、普通（早期対処を推奨）、不良（要対応・収量影響あり）」を表示します。タイトルバーの総合バッジは、追跡項目の中で最も悪い値を反映します。" eh="3b8c2c6e" />

    <e k="helpLine_sf_hu_p2_title" v="フィールドの不利益要素" eh="b4d35b30" />
    <e k="helpLine_sf_hu_p2_press_title" v="雑草、害虫、および病害" eh="0a3fae00" />
    <e k="helpLine_sf_hu_p2_press_text" v="0 〜 100 のスコアで作物への脅威を追跡します。放置すると収量が低下します：雑草 最大 -30%、害虫 -20%、病害 -25%。HUD 行の W、I、D は深刻度を色（緑、黄、赤）で示します。" eh="3fc3c400" />
    <e k="helpLine_sf_hu_p2_treat_title" v="脅威の処理" eh="cb24bf50" />
    <e k="helpLine_sf_hu_p2_treat_text" v="除草剤は雑草を減らし、耕耘も値をゼロにします。殺虫剤は害虫圧を 25 下げ、10 日間抑制します。殺菌剤は病害を 20 下げ、12 日間抑制します。各システムは設定でオフにできます。" eh="4d65bdec" />

    <e k="helpLine_sf_hu_p3_title" v="土壌レポート" eh="35fcce6c" />
    <e k="helpLine_sf_hu_p3_open_title" v="レポートを開く (K キー)" eh="62e3f629" />
    <e k="helpLine_sf_hu_p3_open_text" v="K キーで農場全体の土壌レポートを開きます。サマリーバーには追跡フィールド数、要施肥数、加重平均された農場健全度が表示されます。緊急度の高い順に並べ替えられます。" eh="38a5bd2e" />
    <e k="helpLine_sf_hu_p3_detail_title" v="フィールド詳細と推奨事項" eh="c99d2b89" />
    <e k="helpLine_sf_hu_p3_detail_text" v="各行の矢印をクリックすると、そのフィールドの詳細（養分値、各種圧力、収量減少予測、具体的な推奨散布リスト）が表示されます。Back または Escape で一覧に戻ります。" eh="38dd2c6d" />

    <!-- Category 6: Settings -->
    <e k="helpLine_sf_se_p1_title" v="シミュレーション設定" eh="cbf13e3c" />
    <e k="helpLine_sf_se_p1_server_title" v="サーバー設定（マルチ時は管理者のみ）" eh="49f37ed7" />
    <e k="helpLine_sf_se_p1_server_text" v="肥沃度システム、養分サイクル、季節・雨の影響、耕耘ボーナス、各種圧力、肥料コスト、輪作、自動レート制御などが含まれます。マルチでは管理者のみ変更可能で、全員に即時反映されます。" eh="abca5e43" />
    <e k="helpLine_sf_se_p1_diff_title" v="難易度" eh="7b29ca96" />
    <e k="helpLine_sf_se_p1_diff_text" v="簡易 (0.7x) は消耗を 30% 抑え、リラックスしてプレイできます。リアル (1.0x) は標準設定です。ハードコア (1.5x) は消耗が 50% 増え、過酷な管理が求められます。" eh="ca93ca3e" />

    <e k="helpLine_sf_se_p2_title" v="HUD とレート制御" eh="399f4910" />
    <e k="helpLine_sf_se_p2_hud_title" v="プレイヤーごとの HUD オプション" eh="0df76500" />
    <e k="helpLine_sf_se_p2_hud_text" v="HUD 設定は各プレイヤーで管理され、サーバーには同期されません。表示の有無、位置、配色（グリーン/ブルー/アンバー/モノ）、フォントサイズ、透明度、単位系が設定可能です。" eh="f3934884" />
    <e k="helpLine_sf_se_p2_rate_title" v="スプレイヤー散布量制御" eh="5ecdfa23" />
    <e k="helpLine_sf_se_p2_rate_text" v="スプレイヤー等に乗車中、SFレート上げ（]）と下げ（[）で散布量を 0.10x 〜 2.00x の範囲で調整できます。自動レート制御（Shift+L）を有効にすると、Mod が最適な量を自動で狙います。" eh="dd385e39" />

    <!-- Category 7: Multiplayer -->
    <e k="helpLine_sf_mp_p1_title" v="マルチプレイヤーの仕組み" eh="8a4ce30e" />
    <e k="helpLine_sf_mp_p1_auth_title" v="サーバー主導のシミュレーション" eh="8d324792" />
    <e k="helpLine_sf_mp_p1_auth_text" v="すべての土壌シミュレーションはサーバー上で実行されます。クライアントは参加時に完全なデータと設定を受信します。HUD 設定はプレイヤー固有であり、サーバーとは同期されません。" eh="db72a3f9" />
