    <e k="helpLine_sf_nu_p4_bonus_text" v="Cultivar uma leguminosa (soja, ervilha, feijão) após uma não leguminosa adiciona um bônus de nitrogênio gratuito a cada primavera por 3 dias." eh="e1fce95b" />
    <e k="helpLine_sf_nu_p4_fatigue_title" v="Fadiga de Culturas" eh="236a590c" />
