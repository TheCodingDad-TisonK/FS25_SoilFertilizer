    <e k="helpLine_sf_cat_hud" v="HUD 및 토양 보고서" eh="655b1b40" />
    <e k="helpLine_sf_cat_settings" v="설정" eh="f4f70727" />
    <e k="helpLine_sf_cat_multiplayer" v="멀티플레이어" eh="901a7320" />

    <!-- Category 1: Overview -->
    <e k="helpLine_sf_ov_p1_title" v="기능 설명" eh="46cbb25b" />
    <e k="helpLine_sf_ov_p1_intro_title" v="필드별 토양 추적" eh="8fe3248d" />
    <e k="helpLine_sf_ov_p1_intro_text" v="모든 필드는 질소(N), 인산(P), 칼륨(K), 유기물(OM), pH의 다섯 가지 속성을 독립적으로 추적합니다. 값은 세이브게임에 저장되며 세션 간에 유지됩니다." eh="c30216e6" />
    <e k="helpLine_sf_ov_p1_flow_title" v="영양 순환" eh="15b0d408" />
    <e k="helpLine_sf_ov_p1_flow_text" v="작물은 수확 시 영양분을 소모합니다. 비료, 퇴비, 액비, 석회로 이를 보충해야 합니다. 이 모드는 현실적인 영양 예산을 추적하므로, 작물이 가져간 만큼 다시 채워주어야 합니다." eh="418041f0" />

    <e k="helpLine_sf_ov_p2_title" v="환경 효과" eh="e139e84f" />
    <e k="helpLine_sf_ov_p2_rain_title" v="강우와 용탈" eh="33e0d8ea" />
    <e k="helpLine_sf_ov_p2_rain_text" v="비는 질소를 가장 많이 용탈시키며, 그 다음으로 칼륨, 인산 순입니다. 또한 시간이 지남에 따라 pH를 서서히 산성화시킵니다. 강우 효과는 설정에서 끌 수 있습니다." eh="91e39cc6" />
    <e k="helpLine_sf_ov_p2_season_title" v="계절과 휴경지 회복" eh="ad2009c8" />
    <e k="helpLine_sf_ov_p2_season_text" v="봄에는 하루에 +0.03 질소가 추가됩니다(생물학적 활동). 가을에는 하루에 0.02 질소가 제거됩니다. 7일 이상 작물을 심지 않은 필드는 스스로 영양분을 서서히 회복합니다." eh="e5ebb3b2" />

    <!-- Category 2: Getting Started -->
    <e k="helpLine_sf_gs_p1_title" v="첫 단계" eh="bdd0e0a7" />
    <e k="helpLine_sf_gs_p1_hud_title" v="HUD 열기 (J 키)" eh="e1bdea72" />
    <e k="helpLine_sf_gs_p1_hud_text" v="J 키를 눌러 실시간 토양 오버레이를 전환합니다. 현재 위치한 필드의 N, P, K, pH, OM을 보여줍니다. 좋음 / 보통 / 나쁨 상태 표시를 통해 즉시 관리가 필요한 부분을 알 수 있습니다." eh="53cef520" />
    <e k="helpLine_sf_gs_p1_report_title" v="토양 보고서 열기 (K 키)" eh="e71446cd" />
    <e k="helpLine_sf_gs_p1_report_text" v="K 키를 눌러 농장 전체 토양 보고서를 엽니다. 모든 필드가 영양 상태에 따라 색상별로 표시되며 긴급도순으로 정렬됩니다. 상세 정보와 권장 사항을 보려면 행 옆의 화살표를 클릭하세요." eh="9a0d32a6" />

    <e k="helpLine_sf_gs_p2_title" v="비료 살포 및 수확" eh="1a52ac04" />
    <e k="helpLine_sf_gs_p2_fert_title" v="필드 비료 살포" eh="ea52ec26" />
    <e k="helpLine_sf_gs_p2_fert_text" v="표준 스프레이어나 살포기를 사용하여 비료를 살포하세요. 이 모드는 기본 게임의 모든 유형과 9가지 커스텀 유형(UAN-32, MAP, 칼리 등)을 인식합니다. 유형마다 보충하는 영양분이 다르므로 비료 카테고리의 프로필을 확인하세요." eh="fe906e29" />
    <e k="helpLine_sf_gs_p2_harvest_title" v="수확에 의한 고갈" eh="a67b6cb5" />
    <e k="helpLine_sf_gs_p2_harvest_text" v="수확할 때마다 필드의 영양분이 제거됩니다. 요구량이 많은 작물(감자, 사탕무, 대두)은 가벼운 작물(보리, 귀리)보다 훨씬 더 많이 고갈시킵니다. 수확 주기마다 HUD나 보고서를 다시 확인하세요." eh="63f90ed4" />

    <e k="helpLine_sf_gs_p3_title" v="난이도" eh="7b29ca96" />
    <e k="helpLine_sf_gs_p3_levels_title" v="세 가지 난이도 수준" eh="52611188" />
    <e k="helpLine_sf_gs_p3_levels_text" v="단순(0.7x): 고갈량이 30% 적어 초보자에게 적합합니다. 현실적(1.0x): 실제 농업 비율에 맞춰 조정된 균형 잡힌 수준입니다. 하드코어(1.5x): 고갈량이 50% 많아 집중적인 토양 관리가 필요합니다." eh="f4f1ea30" />
    <e k="helpLine_sf_gs_p3_access_title" v="설정 변경" eh="b421c88f" />
    <e k="helpLine_sf_gs_p3_access_text" v="ESC > 설정 > 토양 및 비료에서 설정을 엽니다. 멀티플레이어에서는 서버 관리자만 시뮬레이션 설정을 변경할 수 있습니다. HUD 표시 옵션은 플레이어별로 설정되며 공유되지 않습니다." eh="4ba9d860" />

    <!-- Category 3: Soil Nutrients -->
    <e k="helpLine_sf_nu_p1_title" v="질소와 인산" eh="27d37372" />
    <e k="helpLine_sf_nu_p1_n_title" v="질소 (N) - 범위 0 ~ 100" eh="10a358f4" />
    <e k="helpLine_sf_nu_p1_n_text" v="이동성이 가장 큰 영양분으로, 가장 빨리 고갈되며 비에 의한 용탈이 심합니다. 나쁨: 30 미만. 좋음: 50 이상. 액상 비료, UAN-32, UAN-28, 무수 암모니아, 요소, AMS, 퇴비, 액비 등으로 높일 수 있습니다." eh="58d62253" />
    <e k="helpLine_sf_nu_p1_p_title" v="인산 (P) - 범위 0 ~ 100" eh="979bba64" />
    <e k="helpLine_sf_nu_p1_p_text" v="토양에 단단히 결합되어 용탈이 매우 느립니다. 주로 수확을 통해 고갈됩니다. 카놀라가 인산 요구량이 가장 높습니다. 나쁨: 25 미만. 좋음: 45 이상. MAP, DAP, 스타터 비료, 액상 비료 등으로 높일 수 있습니다." eh="92c5ac66" />

    <e k="helpLine_sf_nu_p2_title" v="칼륨과 pH" eh="6bd92f25" />
    <e k="helpLine_sf_nu_p2_k_title" v="칼륨 (K) - 범위 0 ~ 100" eh="2a16e8bc" />
    <e k="helpLine_sf_nu_p2_k_text" v="뿌리 및 괴경 작물에 매우 중요합니다. 감자와 사탕무는 수확 시 칼륨을 대량으로 소모합니다. 비에 의해 중간 정도로 용탈됩니다. 나쁨: 20 미만. 좋음: 40 이상. 칼리(0-0-60), 액비, 소화액, 액상 비료 등으로 높일 수 있습니다." eh="7230fee4" />
    <e k="helpLine_sf_nu_p2_ph_title" v="pH - 범위 5.0 ~ 7.5" eh="944beca2" />
    <e k="helpLine_sf_nu_p2_ph_text" v="대부분의 작물은 pH 6.5에서 7.0 사이에서 가장 잘 자랍니다. 비는 시간이 지남에 따라 토양을 서서히 산성화시킵니다. pH는 스스로 회복되지 않으며 석회나 액상 석회로만 높일 수 있습니다. 나쁨: 5.5 미만. 다음 파종 전에 pH가 낮다면 석회를 살포하세요." eh="08e0aefd" />

    <e k="helpLine_sf_nu_p3_title" v="유기물" eh="6305f4bb" />
    <e k="helpLine_sf_nu_p3_om_title" v="유기물 (OM) - 범위 0 ~ 10" eh="58f490f3" />
    <e k="helpLine_sf_nu_p3_om_text" v="매우 천천히 쌓이며 수확에 의해 고갈되지 않습니다. 나쁨: 2.5 미만. 좋음: 4.0 이상. 퇴비, 액비, 소화액, 컴포스트, 바이오솔리드, 계분, 펠렛 퇴비를 살포하거나 볏짚을 썰어 필드에 다시 넣음으로써 높일 수 있습니다." eh="f9a02359" />
    <e k="helpLine_sf_nu_p3_fallow_title" v="휴경지 회복" eh="14133b0b" />
    <e k="helpLine_sf_nu_p3_fallow_text" v="7일 이상 작물을 심지 않은 필드는 서서히 영양분을 회복합니다. 하루당: N +0.07, P +0.03, K +0.05, OM +0.01. 작물 순환과 휴지기는 이 모드에서 실제적인 가치가 있습니다." eh="81fa82b3" />

    <!-- Category 4: Fertilizers -->
    <e k="helpLine_sf_fe_p1_title" v="기본 게임 유형" eh="fd941c0d" />
    <e k="helpLine_sf_fe_p1_base_title" v="액체, 고체, 퇴비 및 액비" eh="4668dca7" />
    <e k="helpLine_sf_fe_p1_base_text" v="액상 비료는 균형 잡힌 N+P+K를 추가합니다. 고체 비료는 N과 P 함량이 높습니다. 퇴비와 액비는 N, P, K 및 유기물을 추가합니다. 소화액(바이오가스 부산물)은 칼륨 함량이 높고 유기물도 추가합니다. 모두 표준 장비로 살포 가능합니다." eh="64069a56" />
    <e k="helpLine_sf_fe_p1_lime_title" v="석회 및 pH 교정" eh="8933cce1" />
    <e k="helpLine_sf_fe_p1_lime_text" v="석회는 기본 게임의 유일한 pH 교정 수단이며 영양분을 추가하지 않습니다. 커스텀 유형인 액상 석회와 석고도 pH를 높입니다(석고는 약간의 유기물도 추가). pH가 6.0 미만으로 떨어지면 작물 성장을 위해 살포하세요." eh="833a967f" />

    <e k="helpLine_sf_fe_p2_title" v="커스텀 질소 및 PK 공급원" eh="1021f8c9" />
    <e k="helpLine_sf_fe_p2_n_title" v="질소 공급원 (커스텀 빅백)" eh="9dfe5a5a" />
    <e k="helpLine_sf_fe_p2_n_text" v="UAN-32(32-0-0) 및 UAN-28(28-0-0)은 액상 질소 솔루션입니다. 무수 암모니아(82-0-0)는 리터당 질소 함량이 가장 높은 제품입니다. 요소(46-0-0) 및 AMS(21-0-0-24S)는 고체 알갱이 형태입니다. 모두 질소(N)만 공급하며 P, K, pH에는 영향이 없습니다." eh="6a100c25" />
    <e k="helpLine_sf_fe_p2_pk_title" v="인산 및 칼륨 공급원" eh="a2d4091b" />
    <e k="helpLine_sf_fe_p2_pk_text" v="MAP(11-52-0): 리터당 인산 함량이 가장 높습니다. DAP(18-46-0): 높은 인산과 약간의 질소를 함유합니다. 칼리(0-0-60): 순수 칼륨. 스타터(10-34-0): 균형 잡힌 N+K와 함께 높은 인산을 함유한 파종 시 살포 제품입니다. 모두 상점에서 빅백으로 구입 가능합니다." eh="75a86964" />

    <e k="helpLine_sf_fe_p3_title" v="유기물 제품 및 과다 살포 위험" eh="7ab807d1" />
    <e k="helpLine_sf_fe_p3_organic_title" v="유기물 및 완효성 제품" eh="0199e6be" />
    <e k="helpLine_sf_fe_p3_organic_text" v="컴포스트는 유기물 증진 효과가 가장 강력합니다(1,000L당 +0.12). 바이오솔리드와 계분은 N, P 및 유기물을 추가합니다. 펠렛 퇴비는 농축된 균형 유기물입니다. 호환되는 장비 모드가 설치된 경우 사용할 수 있습니다." eh="3d16e4ee" />
    <e k="helpLine_sf_fe_p3_burn_title" v="과다 살포 피해 위험" eh="e986cc54" />
    <e k="helpLine_sf_fe_p3_burn_text" v="기본 비율의 1.25배 이상 살포 시 비료 피해 위험이 있습니다(-0.15 pH 및 -5 N). 1.50배 이상인 경우 매 통과 시마다 피해가 확정적으로 발생합니다(-0.30 pH 및 -12 N). 차량에서 SF 살포량 증가/감소 키를 사용하여 살포량을 조절하세요." eh="7bccc46a" />

    <!-- Category 5: HUD and Soil Report -->
    <e k="helpLine_sf_hu_p1_title" v="토양 HUD" eh="6522879b" />
    <e k="helpLine_sf_hu_p1_toggle_title" v="HUD 전환 (J 키)" eh="402283ba" />
    <e k="helpLine_sf_hu_p1_toggle_text" v="J 키를 눌러 실시간 토양 오버레이를 표시하거나 숨깁니다. 현재 있는 필드를 감지하여 N, P, K, pH, OM을 보여줍니다. 잡초, 해충, 병해 설정이 활성화된 경우 해당 항목도 패널 하단에 표시됩니다." eh="3dcb9bfe" />
    <e k="helpLine_sf_hu_p1_status_title" v="상태 확인 방법" eh="291c3aac" />
    <e k="helpLine_sf_hu_p1_status_text" v="각 영양분은 좋음(조치 불필요), 보통(곧 처리 고려), 나쁨(조치 필요 - 수확량 영향)으로 표시됩니다. 제목 표시줄의 전체 상태 배지는 잡초, 해충, 병해를 포함하여 가장 상태가 좋지 않은 항목을 반영합니다." eh="3b8c2c6e" />

    <e k="helpLine_sf_hu_p2_title" v="필드 건강 위협" eh="b4d35b30" />
    <e k="helpLine_sf_hu_p2_press_title" v="잡초, 해충 및 병해" eh="0a3fae00" />
    <e k="helpLine_sf_hu_p2_press_text" v="세 가지 발생 정도(0 ~ 100)는 필드별 생물학적 위협을 추적합니다. 방치하면 수확 시 수확량이 감소합니다: 잡초 최대 -30%, 해충 -20%, 병해 -25%. HUD의 W, I, D 행은 색상별 심각도를 보여줍니다: 초록(낮음), 노랑(보통), 빨강(높음)." eh="3fc3c400" />
    <e k="helpLine_sf_hu_p2_treat_title" v="위협 처리" eh="cb24bf50" />
    <e k="helpLine_sf_hu_p2_treat_text" v="제초제는 잡초 발생을 줄이며, 모든 종류의 경운 작업은 이를 0으로 초기화합니다. 살충제는 해충 발생을 25pt 줄이고 10일 동안 재발생을 억제합니다. 살균제는 병해를 20pt 줄이고 12일 동안 억제합니다. 각 시스템은 설정에서 끌 수 있습니다." eh="4d65bdec" />

    <e k="helpLine_sf_hu_p3_title" v="토양 보고서" eh="35fcce6c" />
    <e k="helpLine_sf_hu_p3_open_title" v="보고서 열기 (K 키)" eh="62e3f629" />
    <e k="helpLine_sf_hu_p3_open_text" v="K 키를 눌러 농장 전체 토양 보고서를 엽니다. 요약 막대에는 추적된 총 필드 수, 비료가 필요한 필드 수, 가중치가 적용된 농장 건강도 백분율이 표시됩니다. 필드는 상태가 나쁜 순서대로 정렬됩니다." eh="38a5bd2e" />
    <e k="helpLine_sf_hu_p3_detail_title" v="필드 상세 및 권장 사항" eh="c99d2b89" />
    <e k="helpLine_sf_hu_p3_detail_text" v="아무 행의 화살표를 클릭하여 해당 필드의 상세 보기를 엽니다: 영양분 수치, 위협 수준, 수확량 손실 예측, 처리해야 할 항목 목록이 표시됩니다. Back이나 Escape 키를 눌러 표로 돌아갑니다." eh="38dd2c6d" />

    <!-- Category 6: Settings -->
    <e k="helpLine_sf_se_p1_title" v="시뮬레이션 설정" eh="cbf13e3c" />
    <e k="helpLine_sf_se_p1_server_title" v="서버 설정 (멀티플레이어에서는 관리자 전용)" eh="49f37ed7" />
    <e k="helpLine_sf_se_p1_server_text" v="비옥도 시스템, 영양 순환, 계절 효과, 강우 효과, 쟁기질 보너스, 잡초/해충/병해, 비료 비용, 알림, 작물 순환, 자동 살포량 제어 등을 설정합니다. 멀티플레이어에서는 서버 관리자만 변경할 수 있으며 모든 클라이언트에 즉시 동기화됩니다." eh="abca5e43" />
    <e k="helpLine_sf_se_p1_diff_title" v="난이도" eh="7b29ca96" />
    <e k="helpLine_sf_se_p1_diff_text" v="단순(0.7x)은 고갈량을 30% 줄여줍니다. 현실적(1.0x)은 기본값입니다. 하드코어(1.5x)는 고갈량을 50% 늘려 집중적인 관리가 필요하게 합니다. ESC > 설정 > 토양 및 비료에서 접근하세요." eh="ca93ca3e" />

    <e k="helpLine_sf_se_p2_title" v="HUD 및 살포량 제어" eh="399f4910" />
    <e k="helpLine_sf_se_p2_hud_title" v="플레이어별 HUD 옵션" eh="0df76500" />
    <e k="helpLine_sf_se_p2_hud_text" v="각 플레이어는 자신의 HUD를 조절할 수 있으며 서버에 동기화되지 않습니다. 옵션: HUD 표시(켜기/끄기), 위치(5가지 사전 설정 + 드래그), 색상 테마(초록/파랑/호박색/단색), 글자 크기, 투명도, 야드파운드법 단위." eh="f3934884" />
    <e k="helpLine_sf_se_p2_rate_title" v="스프레이어 살포량 제어" eh="5ecdfa23" />
    <e k="helpLine_sf_se_p2_rate_text" v="스프레이어나 살포기 탑승 중 SF 살포량 증가(]) 및 감소([) 키를 사용하여 살포량을 0.10배에서 2.00배까지 조절할 수 있습니다. 자동 살포량 제어(Shift+L)를 켜면 모드가 최적 영양 수준을 목표로 자동 조절하며 피해 위험을 방지합니다." eh="dd385e39" />

    <!-- Category 7: Multiplayer -->
    <e k="helpLine_sf_mp_p1_title" v="멀티플레이어 작동 방식" eh="8a4ce30e" />
    <e k="helpLine_sf_mp_p1_auth_title" v="서버 권한 시뮬레이션" eh="8d324792" />
    <e k="helpLine_sf_mp_p1_auth_text" v="모든 토양 시뮬레이션은 서버에서 실행됩니다. 클라이언트는 접속 시 모든 필드 데이터와 설정을 받으며, 서버가 로딩 중인 경우 자동으로 재시도합니다. HUD 표시 설정은 플레이어별로 유지되며 서버와 동기화되지 않습니다." eh="db72a3f9" />
    <e k="helpLine_sf_mp_p1_ded_title" v="전용 서버" eh="4d3a45ba" />
    <e k="helpLine_sf_mp_p1_ded_text" v="전용 서버는 HUD나 GUI 오버헤드 없이 전체 시뮬레이션을 실행합니다. 콘솔 명령(soilStatus, SoilSetDifficulty, SoilShowSettings 등)을 사용하여 전용 서버의 설정을 관리하고 확인할 수 있습니다." eh="3df784d6" />

    <e k="sf_crop_rotation_short" v="작물 순환" eh="def2c162" />
    <e k="sf_crop_rotation_long" v="작물 순환 보너스 및 단일 작물 연작 피해 활성화/비활성화 (콩과 식물은 질소 복구, 동일 작물 연작은 영양분 소모 증가)" eh="958b4212" />
    <e k="sf_report_rotation_bonus" v="순환 보너스" eh="2831a7ac" />
    <e k="sf_report_rotation_fatigue" v="연작 피해: 동일 작물" eh="46135880" />
    <e k="sf_report_rotation_ok" v="작물 순환: 양호" eh="df66b3be" />
    <e k="sf_gypsum_title" v="석고 (pH 저하)" eh="d66da34c" />
    <e k="sf_compost_title" v="컴포스트 (유기질)" eh="c3e2071a" />
    <e k="sf_biosolids_title" v="바이오솔리드 (N+P)" eh="f0c901dc" />
    <e k="sf_chicken_manure_title" v="계분 (N+P)" eh="338128e2" />
    <e k="sf_pelletized_manure_title" v="펠렛 퇴비 (NPK)" eh="c1b39b71" />
    <e k="sf_liquidlime_title" v="액상 석회 (pH 상승)" eh="d4ec4bb9" />
    <e k="helpLine_sf_nu_p4_title" v="작물 순환" eh="def2c162" />
    <e k="helpLine_sf_nu_p4_bonus_title" v="순환 보너스" eh="2831a7ac" />
    <e k="helpLine_sf_nu_p4_bonus_text" v="비콩과 작물 다음에 콩과 작물(대두, 완두 등)을 심으면 매년 봄 3일 동안 무료 질소 보충 효과를 얻습니다." eh="e1fce95b" />
    <e k="helpLine_sf_nu_p4_fatigue_title" v="작물 연작 피해" eh="236a590c" />
    <e k="helpLine_sf_nu_p4_fatigue_text" v="동일한 작물을 2년 연속 심으면 영양분 추출량이 15% 증가합니다. 토양 피로를 피하기 위해 작물을 순환하세요." eh="1613f3c6" />

