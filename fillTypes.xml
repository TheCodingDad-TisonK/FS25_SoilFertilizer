    <fillTypeCategories>
        <!--
            FIX (Issue #96 - Fertilizer won't fill a spreader):
            In FS25, vanilla spreaders look for the "FERTILIZER" category (solid)
            and vanilla sprayers look for the "LIQUIDFERTILIZER" category (liquid).
            By redefining these categories and including the mod's custom types,
            we ensure all compatible vanilla and modded equipment will accept
            UREA, MAP, POTASH, etc.
        -->
        <fillTypeCategory name="FERTILIZER">FERTILIZER UREA AMS MAP DAP POTASH</fillTypeCategory>

        <fillTypeCategory name="LIQUIDFERTILIZER">LIQUIDFERTILIZER UAN32 UAN28 ANHYDROUS STARTER LIQUIDLIME</fillTypeCategory>
    </fillTypeCategories>

</map>